# Server Environment Variables
PORT=5000
NODE_ENV=development

# Database (Currently using JSON file, MongoDB config for future use)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/inventiq?retryWrites=true&w=majority

# API Keys
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET=your_jwt_secret_key_here

# Client URL (Update this when deploying)
CLIENT_URL=http://localhost:5173
